# 阿里云物联网平台认证信息配置模板
# 复制此文件为 .env 并填写您的真实密钥

# 阿里云账号 AccessKey ID
ACCESS_KEY_ID=your_access_key_id_here

# 阿里云账号 AccessKey Secret
ACCESS_KEY_SECRET=your_access_key_secret_here

# 物联网平台所在的地域ID (例如: cn-shanghai, cn-beijing, ap-southeast-1)
REGION_ID=cn-shanghai

# 物联网产品的 ProductKey (在物联网控制台产品详情中获取)
PRODUCT_KEY=your_product_key_here

# 设备名称 (多个设备名可以用逗号分隔，例如: device01,device02)
DEVICE_NAMES=device01,device02
